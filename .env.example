# Backend service base URLs — the BFF (app/api/** via lib/backend.ts) is the
# only consumer. In-cluster these point at the ClusterIP FQDNs; for local dev,
# port-forward each service and use localhost (these defaults).
#
#   kubectl -n order-demo port-forward svc/order           3002:3002 &
#   kubectl -n order-demo port-forward svc/payment         3004:3004 &
#   kubectl -n order-demo port-forward svc/inventory       3003:3003 &
#   kubectl -n order-demo port-forward svc/product-catalog 3005:3005 &
#   kubectl -n order-demo port-forward svc/user-session    3006:3006 &
#
# auth-service (:3001) is intentionally absent — the UI never calls it.
ORDER_URL=http://localhost:3002
PAYMENT_URL=http://localhost:3004
INVENTORY_URL=http://localhost:3003
PRODUCT_CATALOG_URL=http://localhost:3005
USER_SESSION_URL=http://localhost:3006

# Cookie-signing secret for the session cookie (login chunk). Any long random
# string; in-cluster this comes from the Deployment env.
SESSION_SECRET=dev-session-secret-change-me
