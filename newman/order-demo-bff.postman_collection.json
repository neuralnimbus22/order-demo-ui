{
  "info": {
    "name": "order-demo-ui — BFF API contract",
    "description": "Contract tests for the Next.js BFF HTTP API (/api/*) that fronts and orchestrates the order-demo-enterprise services. This is the BFF LAYER — distinct from the backend repo's service-level tests/<service>/. Each request asserts status + response SCHEMA (the shape the browser depends on), derived from the route handlers. Targets {{baseUrl}}; the app is assumed already running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "sessionCookie", "value": "" },
    { "key": "freshEmail", "value": "" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "GET /api/health -> 200 {status:ok}",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/health" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200', () => pm.response.to.have.status(200));",
                "pm.test('schema {status:\"ok\"}', () => {",
                "  pm.response.to.have.jsonSchema({",
                "    type: 'object', required: ['status'], properties: { status: { type: 'string' } }",
                "  });",
                "  pm.expect(pm.response.json().status).to.eql('ok');",
                "});"
              ] }
            }
          ]
        },
        {
          "name": "GET /api/products -> 200 [product]",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.test('is a non-empty array', () => {",
                "  pm.expect(body).to.be.an('array').that.is.not.empty;",
                "});",
                "pm.test('each item matches the product contract', () => {",
                "  pm.response.to.have.jsonSchema({",
                "    type: 'array',",
                "    items: {",
                "      type: 'object',",
                "      required: ['id','name','category','price','stock'],",
                "      properties: {",
                "        id: { type: 'string' },",
                "        name: { type: 'string' },",
                "        category: { type: 'string' },",
                "        price: { type: 'number' },",
                "        description: { type: ['string','null'] },",
                "        stock: { type: 'number' }",
                "      }",
                "    }",
                "  });",
                "});",
                "pm.test('price is a number (typed-field check)', () => {",
                "  pm.expect(body[0].price).to.be.a('number');",
                "  pm.collectionVariables.set('knownSku', body[0].id);",
                "});"
              ] }
            }
          ]
        },
        {
          "name": "GET /api/products/:id (known) -> 200 product",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products/{{knownSku}}" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200', () => pm.response.to.have.status(200));",
                "pm.test('product schema', () => {",
                "  pm.response.to.have.jsonSchema({",
                "    type: 'object',",
                "    required: ['id','name','category','price','stock'],",
                "    properties: {",
                "      id: { type: 'string' }, name: { type: 'string' }, category: { type: 'string' },",
                "      price: { type: 'number' }, description: { type: ['string','null'] }, stock: { type: 'number' }",
                "    }",
                "  });",
                "  pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('knownSku'));",
                "});"
              ] }
            }
          ]
        },
        {
          "name": "GET /api/products/:id (unknown) -> 404 {error}",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/products/NO-SUCH-SKU-000" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('404', () => pm.response.to.have.status(404));",
                "pm.test('error shape', () => {",
                "  pm.response.to.have.jsonSchema({ type: 'object', required: ['error'], properties: { error: { type: 'string' } } });",
                "  pm.expect(pm.response.json().error).to.eql('unknown product');",
                "});"
              ] }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/login (bad password) -> 401 generic, no leak",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"demo@example.com\",\"password\":\"definitely-not-the-password\"}" },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('401', () => pm.response.to.have.status(401));",
                "pm.test('generic error, no detail leak', () => {",
                "  pm.response.to.have.jsonSchema({ type: 'object', required: ['error'], properties: { error: { type: 'string' } } });",
                "  pm.expect(pm.response.json().error).to.eql('Invalid email or password.');",
                "});",
                "pm.test('no Set-Cookie on failed login', () => {",
                "  pm.expect(pm.response.headers.get('Set-Cookie') || '').to.not.include('session=ey');",
                "});"
              ] }
            }
          ]
        },
        {
          "name": "POST /api/auth/login (missing fields) -> 400 {error}",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('400', () => pm.response.to.have.status(400));",
                "pm.test('error shape', () => {",
                "  pm.response.to.have.jsonSchema({ type: 'object', required: ['error'], properties: { error: { type: 'string' } } });",
                "  pm.expect(pm.response.json().error).to.eql('Email and password are required.');",
                "});"
              ] }
            }
          ]
        },
        {
          "name": "POST /api/auth/login (seeded) -> 200 {email} + capture cookie",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"demo@example.com\",\"password\":\"demo-password\"}" },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200', () => pm.response.to.have.status(200));",
                "pm.test('{email} contract (no token in body)', () => {",
                "  pm.response.to.have.jsonSchema({ type: 'object', required: ['email'], properties: { email: { type: 'string' } } });",
                "  pm.expect(pm.response.json().email).to.eql('demo@example.com');",
                "  pm.expect(pm.response.json()).to.not.have.property('token');",
                "});",
                "pm.test('sets a session cookie; capture it', () => {",
                "  const setCookie = pm.response.headers.get('Set-Cookie');",
                "  pm.expect(setCookie, 'Set-Cookie header present').to.be.a('string');",
                "  const m = /session=([^;]+)/.exec(setCookie);",
                "  pm.expect(m, 'session cookie in Set-Cookie').to.not.be.null;",
                "  pm.collectionVariables.set('sessionCookie', m[1]);",
                "});"
              ] }
            }
          ]
        },
        {
          "name": "GET /api/auth/me (no cookie) -> 401 not_authenticated",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/auth/me" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('401', () => pm.response.to.have.status(401));",
                "pm.test('error shape', () => {",
                "  pm.response.to.have.jsonSchema({ type: 'object', required: ['error'], properties: { error: { type: 'string' } } });",
                "  pm.expect(pm.response.json().error).to.eql('not_authenticated');",
                "});"
              ] }
            }
          ]
        },
        {
          "name": "GET /api/auth/me (with cookie) -> 200 {email,exp}",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "session={{sessionCookie}}" }],
            "url": "{{baseUrl}}/api/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200', () => pm.response.to.have.status(200));",
                "pm.test('{email, exp} contract', () => {",
                "  pm.response.to.have.jsonSchema({",
                "    type: 'object', required: ['email','exp'],",
                "    properties: { email: { type: 'string' }, exp: { type: 'number' } }",
                "  });",
                "  pm.expect(pm.response.json().email).to.eql('demo@example.com');",
                "});"
              ] }
            }
          ]
        },
        {
          "name": "POST /api/auth/register (fresh unique) -> 201 {email}",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"{{freshEmail}}\",\"password\":\"newman-contract-pw\"}" },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": [
                "pm.collectionVariables.set('freshEmail', 'newman-' + Date.now() + '@example.com');"
              ] }
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('201', () => pm.response.to.have.status(201));",
                "pm.test('{email} contract', () => {",
                "  pm.response.to.have.jsonSchema({ type: 'object', required: ['email'], properties: { email: { type: 'string' } } });",
                "  pm.expect(pm.response.json().email).to.eql(pm.collectionVariables.get('freshEmail'));",
                "});"
              ] }
            }
          ]
        },
        {
          "name": "POST /api/auth/register (duplicate seeded) -> 409 {error}",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"demo@example.com\",\"password\":\"whatever-password\"}" },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('409', () => pm.response.to.have.status(409));",
                "pm.test('already-exists error shape', () => {",
                "  pm.response.to.have.jsonSchema({ type: 'object', required: ['error'], properties: { error: { type: 'string' } } });",
                "  pm.expect(pm.response.json().error).to.eql('An account with this email already exists.');",
                "});"
              ] }
            }
          ]
        },
        {
          "name": "POST /api/auth/logout -> 200 {ok:true}",
          "request": { "method": "POST", "url": "{{baseUrl}}/api/auth/logout" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200', () => pm.response.to.have.status(200));",
                "pm.test('{ok:true} contract', () => {",
                "  pm.response.to.have.jsonSchema({ type: 'object', required: ['ok'], properties: { ok: { type: 'boolean' } } });",
                "  pm.expect(pm.response.json().ok).to.eql(true);",
                "});"
              ] }
            }
          ]
        }
      ]
    },
    {
      "name": "Protected (cookie-gated)",
      "item": [
        {
          "name": "GET /api/orders/:id/status (no cookie) -> 401",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/orders/contract-probe-id/status" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('401', () => pm.response.to.have.status(401));",
                "pm.test('not_authenticated error', () => {",
                "  pm.response.to.have.jsonSchema({ type: 'object', required: ['error'], properties: { error: { type: 'string' } } });",
                "  pm.expect(pm.response.json().error).to.eql('not_authenticated');",
                "});"
              ] }
            }
          ]
        },
        {
          "name": "GET /api/orders/:id/status (with cookie) -> 200 fulfillment",
          "description": "An arbitrary id returns 200 because getFulfillment normalizes inventory's not-seen 404 into a waiting-for-both state. This exercises the cookie-gated route WITHOUT placing an order.",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "session={{sessionCookie}}" }],
            "url": "{{baseUrl}}/api/orders/contract-probe-id/status"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('200', () => pm.response.to.have.status(200));",
                "pm.test('fulfillment schema', () => {",
                "  pm.response.to.have.jsonSchema({",
                "    type: 'object',",
                "    required: ['id','orderPlaced','paymentConfirmed','fulfilled','waitingFor'],",
                "    properties: {",
                "      id: { type: 'string' },",
                "      orderPlaced: { type: ['string','null'] },",
                "      paymentConfirmed: { type: ['string','null'] },",
                "      fulfilled: { type: 'boolean' },",
                "      waitingFor: { type: 'array', items: { type: 'string' } }",
                "    }",
                "  });",
                "});",
                "pm.test('waitingFor is an array (typed-field check)', () => {",
                "  pm.expect(pm.response.json().waitingFor).to.be.an('array');",
                "});"
              ] }
            }
          ]
        }
      ]
    },
    {
      "name": "Checkout (guards only — no real order placed)",
      "item": [
        {
          "name": "POST /api/checkout (logged-out) -> 401",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"lines\":[]}" },
            "url": "{{baseUrl}}/api/checkout"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('401', () => pm.response.to.have.status(401));",
                "pm.test('not_authenticated error', () => {",
                "  pm.response.to.have.jsonSchema({ type: 'object', required: ['error'], properties: { error: { type: 'string' } } });",
                "  pm.expect(pm.response.json().error).to.eql('not_authenticated');",
                "});"
              ] }
            }
          ]
        },
        {
          "name": "POST /api/checkout (logged-in, empty cart) -> 400 empty_cart",
          "description": "Asserts the validation guard WITHOUT placing a real order — sends an empty lines[] with a valid session, expecting the empty_cart rejection.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "session={{sessionCookie}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"lines\":[]}" },
            "url": "{{baseUrl}}/api/checkout"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('400', () => pm.response.to.have.status(400));",
                "pm.test('empty_cart error', () => {",
                "  pm.response.to.have.jsonSchema({ type: 'object', required: ['error'], properties: { error: { type: 'string' } } });",
                "  pm.expect(pm.response.json().error).to.eql('empty_cart');",
                "});"
              ] }
            }
          ]
        }
      ]
    }
  ]
}
